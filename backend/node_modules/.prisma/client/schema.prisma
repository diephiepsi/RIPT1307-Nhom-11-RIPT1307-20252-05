generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql" // Đổi từ postgresql sang mysql
}

model User {
  id                    String         @id @default(cuid()) @db.VarChar(30)
  email                 String         @unique(map: "uq_users_email") @db.VarChar(150)
  fullName              String         @map("full_name") @db.VarChar(100)
  password              String         @db.VarChar(255)
  role                  users_role     @default(STUDENT)
  locked                Boolean        @default(false) @map("is_locked")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at")
  comments              Comment[]
  questions             Question[]
  votes                 Vote[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationSender")

  @@map("users")
}

model Tag {
  id        String        @id @default(cuid()) @db.VarChar(30)
  name      String        @unique(map: "uq_tags_name") @db.VarChar(100)
  questions QuestionTag[]

  @@map("tags")
}

model Question {
  id         String        @id @default(cuid()) @db.VarChar(30)
  title      String        @db.VarChar(255)
  content    String        @db.LongText
  isApproved Boolean       @default(false) @map("is_approved") // Trạng thái duyệt bài
  authorId   String        @map("user_id") @db.VarChar(30)
  deletedAt  DateTime?     @map("deleted_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at")
  comments   Comment[]
  tags       QuestionTag[]
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_posts_user")
  votes      Vote[]

  @@index([authorId], map: "fk_posts_user")
  @@index([createdAt], map: "idx_posts_created_at")
  @@map("posts")
}

model QuestionTag {
  questionId String   @map("post_id") @db.VarChar(30)
  tagId      String   @map("tag_id") @db.VarChar(30)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_post_tags_post")
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_post_tags_tag")

  @@id([questionId, tagId])
  @@index([tagId], map: "fk_post_tags_tag")
  @@map("post_tags")
}

model Comment {
  id         String    @id @default(cuid()) @db.VarChar(30)
  content    String    @db.Text
  questionId String    @map("post_id") @db.VarChar(30)
  authorId   String    @map("user_id") @db.VarChar(30)
  parentId   String?   @map("parent_id") @db.VarChar(30)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_parent")
  replies    Comment[] @relation("CommentReplies")
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_post")
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comments_user")
  votes      Vote[]

  @@index([parentId], map: "fk_comments_parent")
  @@index([authorId], map: "fk_comments_user")
  @@index([questionId], map: "idx_comments_post_id")
  @@map("comments")
}

model Vote {
  id         String    @id @default(cuid()) @db.VarChar(30)
  value      Int
  userId     String    @map("user_id") @db.VarChar(30)
  questionId String?   @map("post_id") @db.VarChar(30)
  commentId  String?   @map("comment_id") @db.VarChar(30)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  comments   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_comment")
  posts      Question? @relation(fields: [questionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_post")
  users      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_votes_user")

  @@unique([userId, commentId], map: "uq_vote_user_comment")
  @@unique([userId, questionId], map: "uq_vote_user_post")
  @@index([commentId], map: "idx_votes_comment_id")
  @@index([questionId], map: "idx_votes_post_id")
  @@map("votes")
}

model Notification {
  id          String   @id @default(cuid()) @db.VarChar(30)
  recipientId String   @map("recipient_id") @db.VarChar(30)
  senderId    String   @map("sender_id") @db.VarChar(30)
  type        String   @db.VarChar(20) // "LIKE" hoặc "COMMENT"
  content     String   @db.VarChar(255)
  targetId    String   @map("target_id") @db.VarChar(30)
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_recipient")
  sender    User @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_sender")

  @@index([recipientId], map: "idx_notifications_recipient")
  @@index([senderId], map: "fk_notifications_sender")
  @@map("notifications")
}

enum users_role {
  STUDENT
  LECTURER
  ADMIN
}
