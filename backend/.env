PORT=3000

# MySQL — chạy script sql/student_forum.sql trước khi start backend
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=diep12345
DB_DATABASE=student_forum

# Prisma / adapter (tự ghép từ DB_* nếu bỏ trống DATABASE_URL)
DATABASE_URL=mysql://root:diep12345@localhost:3306/student_forum
JWT_SECRET=my_super_secret_key

# SMTP (gửi mail khi có bài mới / bình luận mới / reset mật khẩu)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=app_password
MAIL_FROM=Diễn đàn Hỏi Đáp <your_email@gmail.com>
